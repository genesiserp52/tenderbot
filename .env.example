# Copy this file to .env and fill in your values. Never commit .env.

# --- Telegram (required to actually send notifications) ---
# Create a bot with @BotFather to get the token.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyZ
# Your personal chat ID. Get it by messaging your bot once, then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and reading message.chat.id  (or message @userinfobot).
TELEGRAM_CHAT_ID=987654321

# --- Data source ---
# "auto"   : use the official API if TENDER_API_TOKEN is set, else scrape (default)
# "api"    : force the API (fails if no/invalid token)
# "scrape" : force Playwright scraping of the website
TENDERBOT_SOURCE=auto
# Official open-data API Bearer token (from the procurement agency). When set,
# this is used instead of scraping — no Cloudflare, structured JSON, far more
# robust. Leave blank to scrape.
TENDER_API_TOKEN=
# API endpoint (rarely needs changing).
TENDER_API_URL=https://opendata.tender.gov.mn/api/invitation
# Records fetched per API page (1..100).
TENDERBOT_PER_PAGE=100

# --- Paths (optional; sensible defaults shown) ---
# SQLite database file.
TENDERBOT_DB=data/tenders.db
# Filter rules file.
TENDERBOT_FILTERS=filters.yaml

# --- Scraper tuning (optional) ---
# Max listing pages to scrape per run (20 tenders per page).
TENDERBOT_MAX_PAGES=3
# Run the browser headless (true on a server). Set false to debug locally.
TENDERBOT_HEADLESS=true
# Browser to drive: "chrome" or "msedge" (real installed browser — best at
# passing Cloudflare) or "chromium" (Playwright's bundled build). On a Linux
# VPS install Chrome, or set this to "chromium" and run `playwright install`.
TENDERBOT_BROWSER_CHANNEL=chrome
# Minutes between scrape cycles when running in --loop mode.
TENDERBOT_INTERVAL_MINUTES=45
# Seconds to wait between Telegram messages (rate-limit politeness).
TENDERBOT_NOTIFY_DELAY=1.5
